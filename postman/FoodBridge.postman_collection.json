    {
      "name": "8. Error cases worth showing",
      "item": [
        {
          "name": "No token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/food",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "food"
              ]
            },
            "description": "Remove the Authorization header (Authorization tab > No Auth) and send. Every data endpoint is protected, so this returns 401 Unauthorized."
          },
          "response": []
        },
        {
          "name": "Admin route with a donor token (403)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "users"
              ]
            },
            "description": "Sign in as the donor, then send this. Returns 403 Forbidden.\n\nThis is the point worth making in a viva: hiding the Administration link in the React menu is convenience, not security. The real boundary is here, on the server, and it holds even when the browser is bypassed entirely."
          },
          "response": []
        },
        {
          "name": "Validation error (422)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/food",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "food"
              ]
            },
            "description": "A title shorter than 3 characters violates the Pydantic schema, so FastAPI rejects the request before any of my code runs and returns 422 with a field-by-field explanation.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"x\",\n  \"quantity\": \"1\",\n  \"pickup_address\": \"somewhere\",\n  \"expiry_date\": \"2026-12-31T18:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    }
  ]
