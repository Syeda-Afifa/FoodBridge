# Copy this file to .env and fill in real values.
# NEVER commit the real .env — it is listed in .gitignore.

JWT_SECRET_KEY=change-me-to-a-long-random-string
PASSWORD_PEPPER=change-me-to-another-long-random-string

# Comma-separated list of allowed frontend origins
CORS_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173

# Cookie flags — keep these false/lax for local HTTP development.
# In production (HTTPS) set COOKIE_SECURE=true and COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
